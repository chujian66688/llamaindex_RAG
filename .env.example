# ============================================================
# Tuling-Ai 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================


# ============================================================
# 1. 模型 API 配置（必填，选择一个提供商即可）
# ============================================================

# --- 阿里云 DashScope（推荐） ---
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- OpenAI ---
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- 智谱 AI ---
# ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# --- 腾讯混元 ---
# HUNYUAN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# 2. 数据库配置（必填）
# ============================================================

# PostgreSQL 连接串（用于 LangGraph checkpointer 和长期记忆）
# 格式：postgresql+psycopg://用户名:密码@主机:端口/数据库名
POSTGRES_URL=postgresql+psycopg://postgres:your_password@127.0.0.1:5432/langgraph_agents

# PostgreSQL 连接串（纯 postgresql 协议，供 LangGraph SDK 使用）
POSTGRES_URI_CUSTOM=postgresql://postgres:your_password@127.0.0.1:5432/langgraph_agents?sslmode=disable


# ============================================================
# 3. 服务端口配置（可选，使用默认值即可）
# ============================================================

# RAG API 服务
# RAG_API_HOST=0.0.0.0
# RAG_API_PORT=8011

# MCP 服务
# MCP_SERVICE_URL=http://127.0.0.1:8010/mcp

# LangGraph 服务
# LANGGRAPH_API_URL=http://127.0.0.1:2024
# LANGGRAPH_ASSISTANT_ID=multi_agent

# RAG API 完整地址
# RAG_API_URL=http://127.0.0.1:8011/api/docs


# ============================================================
# 4. JWT 鉴权配置（可选，建议修改）
# ============================================================

# JWT 密钥（建议使用随机生成的强密钥）
# JWT_SECRET_KEY=your-super-secret-key-change-me

# JWT 算法
# JWT_ALGORITHM=HS256

# Token 过期时间（分钟）
# ACCESS_TOKEN_EXPIRE_MINUTES=120

# 刷新 Token 过期时间（天）
# REFRESH_TOKEN_EXPIRE_DAYS=7


# ============================================================
# 5. 模型参数配置（可选）
# ============================================================

# 模型温度参数（0.0-1.0，越低越确定性）
# MODEL_TEMPERATURE=0.1


# ============================================================
# 6. RAG 配置（可选）
# ============================================================

# Embedding 模型路径（本地模型路径或 HuggingFace 模型名）
# EMBEDDING_MODEL_PATH=D:\llm\Local_model\BAAI\bge-small-zh-v1___5

# Rerank 模型路径
# RERANK_MODEL_PATH=D:\llm\Local_model\BAAI\bge-reranker-large

# 文本分块大小
# CHUNK_SIZE=512

# 分块重叠大小
# CHUNK_OVERLAP=50

# 向量检索返回数量
# SIMILARITY_TOP_K=5

# 重排后保留数量
# RERANK_TOP_K=3


# ============================================================
# 7. 第三方服务 API（可选，用于增强功能）
# ============================================================

# Tavily 搜索 API（知识库兜底搜索）
# 申请地址：https://tavily.com
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace Token（下载模型用）
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 天气 API（可选）
# WEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Maps API（可选）
# GMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith API（可选，用于调试追踪）
# 申请地址：https://smith.langchain.com
# LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# 8. Redis 配置（可选，使用默认值即可）
# ============================================================

# Redis 连接地址（rag_api_service 使用）
# 默认连接 127.0.0.1:6379，无需密码
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=


# ============================================================
# 配置说明
# ============================================================
#
# 必填配置：
#   1. DASHSCOPE_API_KEY 或其他模型 API Key（至少配置一个）
#   2. POSTGRES_URL（PostgreSQL 连接串）
#
# 可选配置：
#   - 其他模型 API Key（用于切换模型提供商）
#   - JWT_SECRET_KEY（不设置会使用默认值，建议生产环境修改）
#   - TAVILY_API_KEY（不设置则知识库兜底搜索功能不可用）
#   - RAG 配置（使用默认值即可，根据文档特点可调整）
#
# 端口配置：
#   - 所有服务端口都有默认值，一般无需修改
#   - 如有端口冲突，可取消注释并修改对应配置
#
# ============================================================
